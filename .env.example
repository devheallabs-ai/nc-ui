# NC UI — Environment Variables
#
# Copy this file to .env and fill in your values.
# All variables are optional — NC UI works out of the box without them.

# ═══════════════════════════════════════════════════════════
#  Server Configuration
# ═══════════════════════════════════════════════════════════

# Port for the NC UI development server
# PORT=3000

# ═══════════════════════════════════════════════════════════
#  Security
# ═══════════════════════════════════════════════════════════

# Maximum request body size in bytes (default: 1MB)
# NCUI_MAX_BODY_BYTES=1048576

# Rate limiting
# NCUI_RATE_LIMIT_MAX=100
# NCUI_RATE_LIMIT_WINDOW_MS=60000

# Trust proxy headers (set to "true" behind a reverse proxy)
# NCUI_TRUST_PROXY=false

# Enforce same-origin requests
# APP_ENFORCE_SAME_ORIGIN=false

# ═══════════════════════════════════════════════════════════
#  Audit Logging
# ═══════════════════════════════════════════════════════════

# Enable the audit API endpoint
# NCUI_ENABLE_AUDIT_API=false

# Bearer token for the audit endpoint
# NCUI_AUDIT_TOKEN="your-audit-token-here"

# Path to the audit log file
# NCUI_AUDIT_LOG_PATH="./audit.log"
