page "NC Agentic AI Demo"
theme "dark"
accent "#7c3aed"
font "Inter"

state query is ""
state result is ""
state loading is false
state agentLog is []

action runAgent with text:
    set loading to true
    add {step: "Plan", detail: "Analyzing: " + text} to agentLog
    add {step: "Act", detail: "Calling search tool..."} to agentLog
    add {step: "Observe", detail: "Processing results..."} to agentLog
    add {step: "Finish", detail: "Generating answer"} to agentLog
    set result to "Agent completed research on: " + text
    set loading to false

nav:
    brand "NC Agent Demo"
    links:
        link "Demo" to "#demo"
        link "How It Works" to "#how"
        link "NC Code" to "#code"
        button "Get NC" links to "https://nc.devheallabs.in" style "primary"

section hero centered:
    badge "First-Class Agent Support"
    heading "Agentic AI in NC" style "gradient"
    subheading "Build autonomous AI agents in 15 lines of plain English"
    text "No LangChain. No CrewAI. No Python. Just NC."
    animate "fade-up"

section demo:
    heading "Try the Agent" style "gradient"
    text "Enter a research question and watch the Plan-Act-Observe loop"
    card:
        form action "#":
            input "What would you like to research?" bind query
                placeholder "e.g., What is quantum computing?"
            button "Run Agent" on click runs runAgent with query style "primary"

    if state.loading:
        text "Agent is thinking..."

    if state.agentLog:
        heading "Agent Log"
        repeat for each log in agentLog:
            card:
                badge log.step
                text log.detail

    if state.result:
        card:
            heading "Result"
            text state.result

    animate "fade-up"

section how:
    heading "How NC Agents Work"
    text "The Plan-Act-Observe loop — built into the language"
    grid 3 columns:
        card icon "brain":
            heading "1. Plan"
            text "Agent analyzes the task and decides which tools to use. NOVA LM provides intent-aware reasoning."
        card icon "rocket":
            heading "2. Act"
            text "Agent calls exactly ONE tool per step with structured JSON: {\"action\": \"search\", \"input\": {...}}"
        card icon "check":
            heading "3. Observe"
            text "Agent reads tool output, decides to continue or finish. Uses {\"action\": \"finish\", \"result\": \"...\"} when done."
    animate "stagger"

section code:
    heading "NC vs Python" style "gradient"
    text "15 lines of NC replaces 60+ lines of Python + LangChain"
    grid 2 columns:
        card:
            heading "NC — 15 lines"
            text "@tool"
            text "to search with query:"
            text "    gather results from URL"
            text "    respond with results"
            text ""
            text "agent researcher:"
            text "    purpose: \"Research topics\""
            text "    tools: [search]"
            text "    max_steps: 5"
            text ""
            text "run agent researcher with question"
            text "    save as: answer"
        card:
            heading "Python + LangChain — 60+ lines"
            text "from langchain.agents import initialize_agent"
            text "from langchain.tools import Tool"
            text "from langchain.llms import OpenAI"
            text "import requests"
            text "..."
            text "def search(query):"
            text "    resp = requests.get(url)"
            text "    return resp.json()"
            text "..."
            text "tools = [Tool(name='search', ...)]"
            text "agent = initialize_agent(tools, llm, ...)"
            text "result = agent.run(question)"
    animate "fade-up"

footer:
    text "© 2026 DevHeal Labs AI — Built with NC"
    row centered:
        link "NC Language" to "https://nc.devheallabs.in"
        link "NC AI" to "https://ncai.devheallabs.in"
        link "GitHub" to "https://github.com/DevHeal-Labs"
